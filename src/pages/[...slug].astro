---
// src/pages/[...slug].astro (個別記事ページのテンプレート)
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro'; // レイアウトへのパスが変わることに注意
import CategoryHeader from '../components/CategoryHeader.astro';
import Sidebar from '../components/Sidebar.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const psychologyPosts = await getCollection('psychology');
  const allPosts = [...blogPosts, ...psychologyPosts];

  return allPosts.map((post) => {
    // params.slug に設定する値を決定
    let slugPath;
    if (post.data.url) {
      // フロントマターのurlがあれば、それをパスとする
      slugPath = post.data.url;
    } else {
      // なければファイルパスに基づくパス (例: 'blog/html/html-custom')
      // post.id は 'blog/html/html-custom.md' のようなので、
      // ディレクトリ部分 + ファイル名(拡張子なし) を使う
      slugPath = post.id.replace(/\.md$/, ''); // .mdを除去
    }

    return {
      // params.slug は Astro.params.slug でアクセスでき、
      // URL の '/.../' の部分の文字列になる
      params: { slug: slugPath },
      props: { post }, // 記事データを渡す
    };
  });
}

const { post } = Astro.props;

const categoryHeaderMap = {
  blog: 'ブログ',
  mental: 'メンタル改善',
  motivation: 'モチベーション',
};

function getCategoryHeaderTitle(post) {
  if (post.collection === 'blog') {
    return categoryHeaderMap.blog;
  }
  if (post.collection === 'psychology') {
    return categoryHeaderMap[post.data.category];
  }
}

const { Content } = await post.render();
---

<BaseLayout title={post.data.title}>
  <CategoryHeader title={getCategoryHeaderTitle(post)} />
  <div class="content-flex">
    <article class="content-background">
      <h1>{post.data.title}</h1>
      <p>{post.data.pubDate.toLocaleDateString('ja-JP').replace(/\//g, '.')}</p>
      <img
        src={post.data.featureImage}
        alt={post.data.featureImageAlt}
        loading="lazy"
      />
      <Content />
    </article>
    <Sidebar />
  </div>
</BaseLayout>



<style>
.content-flex {
  display: flex;
  align-items: flex-start;
  max-width: 1000px;
  margin: 200px auto 0;
}

.content-background {
  padding: 30px;
  background-color: white;
  max-width: 700px;
}

.content-background img {
  max-width: 100%;
}

:global(.content-background p),
:global(.content-background h1),
:global(.content-background h2),
:global(.content-background h3),
:global(.content-background h4),
:global(.content-background h5),
:global(.content-background h6),
:global(.content-background li),
:global(.content-background a){
  color: #000;
  line-height: 1.8;
}

@media screen and (max-width:1100px) {
  .content-flex {
    display: block;
  }

  .content-background {
    margin: 0 auto;
    max-width: 540px;
    padding: 30px 20px;
  }

}
</style>