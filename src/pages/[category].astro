---
// src/pages/category/[category].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro'; // 適切なレイアウトを指定
import CategoryHeader from '../components/CategoryHeader.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('psychology'); // すべての記事を取得

  // ユニークなカテゴリ一覧を作る
  const uniqueCategory = new Set<string>();
    allPosts.forEach((post) => {
      if (post.data.category) {
      uniqueCategory.add(post.data.category);
      }
    });

  // 2. 各タグに対応するページ情報を作成
  return Array.from(uniqueCategory).map((category) => {
    // 3. このタグが含まれる記事だけをフィルタリング
    const filteredPosts = allPosts.filter((post) =>
      post.data.category?.includes(category)
    );
    // 4. ページのパスと渡すデータを返す
    return {
      params: { category: category }, // URLの [category] 部分になる値
      props: {
        category: category, // ページコンポーネントで使うカテゴリ名
        posts: filteredPosts, // このカテゴリの記事リスト
      },
    };
  });
}

// getStaticPathsから渡されたデータを受け取る
const { category, posts } = Astro.props;
// 記事を日付順にソート (任意)
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// URLを決定するヘルパー関数 (個別記事ページへのリンク用、前の手順から流用)
function getPostUrl(post) {
  if (post.data.url) {
    return `/${post.data.url}/`;
  }
  return `/${post.slug}`;
}

const categoryMap = {
  mental: 'メンタル改善',
  motivation: 'モチベーション',
};

const categories = Astro.params.category;

const categoryTitle = categoryMap[categories];
---

<BaseLayout title={`${categoryTitle}一覧 - こころ和む心理学`}>
<CategoryHeader title={categoryTitle} />
<div class="contents">
  <ul>
    {posts.map((post) => (
    <a class="post-link" href={getPostUrl(post)}>
      <li class="item">
        <img
          src={post.data.featureImage}
          alt={post.data.featureImageAlt}
          loading="lazy"
        />
        <p>{post.data.title}</p>
        <span>{post.data.pubDate.toLocaleDateString('ja-JP').replace(/\//g, '.')}</span>
      </li>
    </a>
    ))}
  </ul>
</div>
</BaseLayout>

<style>
.contents {
  max-width: 1000px;
  margin: 200px auto 0;
}

.contents ul{
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  justify-items: center;
  gap: 60px 20px;
  padding: 0;
  margin: 0 20px;
  list-style: none;
}

.item {
  width: 250px;
  height: 300px;
  border: 3px solid #000;
  border-radius: 16px;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}

.item img {
  border-radius: 16px 16px 0 0;
}

.item span {
  margin: auto 20px 10px 0;
  text-align: right;
}

.item p {
  font-weight: bold;
  margin: 16px 20px 0 20px;
}

.post-link {
  display: block;
  text-align: center;
  color: #604461;
  text-decoration: none;
}
</style>