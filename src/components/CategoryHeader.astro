---
import { Image } from "astro:assets";
import cloud from "../assets/images/cloud.webp";
import rectangle from "../assets/images/rectangle.webp";
import '../styles/global.css';

const { title } = Astro.props;
---
<div class="container">
  <div class="title">
    <div class="image-container">
      <Image src={rectangle} alt="" class="rectangle" width={1200} height={150} />
      <Image src={cloud} alt="" class="cloud" width={367} height={302} />
      <h1 class="text">{title}</h1>
    </div>
    <div class="triangle-container">
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
      <span class="triangle"></span>
    </div>
  </div>
</div>


<style>
.container{
  margin: 0 auto;
}

.rectangle {
  width: 100%;
  height: 150px;
}

.triangle-container {
  position: relative;
}

.image-container {
  position: relative;
}

.cloud {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.text {
  position: absolute;
  top: 90%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 36px;
}

.triangle {
  width: 25px;
  height: 25px;
  background-color: #FFEE7D;
  clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
  position: absolute;
}

.triangle:nth-child(1) {
  top: -15px;
  left: 27%;
  transform: rotate(22deg);
}

.triangle:nth-child(2) {
  top: 40px;
  left: 22%;
  transform: rotate(13deg);
}

.triangle:nth-child(3) {
  top: 70px;
  left: 26%;
  transform: rotate(-18deg);
  background-color: #C4D700;
}

.triangle:nth-child(4) {
  top: 120px;
  left: 21%;
  transform: rotate(180deg);
  background-color: #C4D700;
}

.triangle:nth-child(5) {
  top: 130px;
  left: 28%;
  transform: rotate(35deg);
  background-color: #C4D700;
}

.triangle:nth-child(6) {
  top: 140px;
  left: 33%;
  transform: rotate(22deg);
}

.triangle:nth-child(7) {
  top: -100px;
  left: 70%;
  transform: rotate(-9deg);
}

.triangle:nth-child(8) {
  top: -90px;
  left: 75%;
  transform: rotate(-22deg);
  background-color: #C4D700;
}

.triangle:nth-child(9) {
  top: -50px;
  left: 82%;
  transform: rotate(14deg);
  background-color: #C4D700;
}

.triangle:nth-child(10) {
  top: -20px;
  left: 74%;
  transform: rotate(59deg);
  background-color: #C4D700;
}

.triangle:nth-child(11) {
  top: 10px;
  left: 78%;
}

.triangle:nth-child(12) {
  top: 40px;
  left: 85%;
  transform: rotate(19deg);
}

@media screen and (max-width: 768px) {
  .cloud {
    width: 250px;
    height: auto;
    top: 40px;
  }

  .text {
    font-size: 24px;
  }

  .triangle:nth-child(1) {
    top: -10px;
    left: 10%;
    transform: rotate(22deg);
  }

  .triangle:nth-child(2) {
    top: 30px;
    left: 18%;
    transform: rotate(13deg);
  }

  .triangle:nth-child(3) {
    top: 55px;
    left: 6%;
    transform: rotate(-18deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(4) {
    top: 80px;
    left: 21%;
    transform: rotate(180deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(5) {
    top: 90px;
    left: 12%;
    transform: rotate(35deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(6) {
    top: 100px;
    left: 33%;
    transform: rotate(22deg);
  }

  .triangle:nth-child(7) {
    top: -90px;
    left: 75%;
    transform: rotate(-9deg);
  }

  .triangle:nth-child(8) {
    top: -70px;
    left: 85%;
    transform: rotate(-22deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(9) {
    top: -30px;
    left: 95%;
    transform: rotate(14deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(10) {
    top: 0px;
    left: 83%;
    transform: rotate(59deg);
    background-color: #C4D700;
  }

  .triangle:nth-child(11) {
    top: 30px;
    left: 73%;
  }

  .triangle:nth-child(12) {
    top: 50px;
    left: 90%;
    transform: rotate(19deg);
}
</style>