---
import '../styles/global.css';

const { posts, title } = Astro.props;

function getPostUrl(post) {
  if (post.data.url) {
    return `/${post.data.url}/`;
  }
  return `/psychology/${post.slug}/`;
}

function formatDate(date) {
  return date.toLocaleDateString('ja-JP').replace(/\//g, '.');
}

const categoryMap = {
  mental: 'メンタル改善',
  motivation: 'モチベーション',
};

function formatCategory(category) {
  return categoryMap[category];
}
---

<div class="container">
  <div class="news-inner">
    <div class="news-header">
      <h2>{title}</h2>
    </div>
    <div class="news-list">
      {posts.map((post) => (
        <article class="news-card">
          <a href={getPostUrl(post)}>
            <div class="news-body">
              <span class="news-date">{formatDate(post.data.pubDate)}</span>
              <span class="news-category">{formatCategory(post.data.category)}</span>
              <p>{post.data.title}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
    <div class="news-link-wrapper">
      <a class="news-link" href="/news-list/">続きを見る</a>
    </div>
  </div>
</div>

<style>
.container {
  margin-bottom: 100px;
}

.news-inner {
  max-width: 60%;
  margin: 0 auto;
}

.news-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 32px;
}

.news-header h2 {
  margin: 0 auto;
  font-size: 2rem;
}

.news-link-wrapper {
  text-align: center;
  margin-top: 20px;
}

.news-link {
  text-decoration: none;
}

.news-list {
  position: relative;
  border-top: 1px solid #D2D2D2;
}

.news-list::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 35px;
  height: 1px;
  background-color: #47619E;
}

.news-card {
  position: relative;
  border-bottom: 1px solid #D2D2D2;
}

.news-card::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  width: 35px;
  height: 1px;
  background-color: #47619E;
}

.news-card a {
  color: inherit;
  text-decoration: none;
  display: block;
}

.news-body {
  padding: 10px 0;
}

.news-category {
  padding: 0 8px;
  margin-bottom: 8px;
  background-color: #D2E7BF;
  border-radius: 999px;
}

.news-date {
  margin-bottom: 12px;
  margin-right: 8px;
}


@media screen and (max-width: 768px) {
  .news-inner {
    max-width: 80%;
  }
}
</style>

