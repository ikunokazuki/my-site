---
const { title = "My Site" } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <p>My Astro Blog</p>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© My Blog</p>
    </footer>
  </body>
</html>
